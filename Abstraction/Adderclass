package abstraction;

public abstract class Adderclass {

    private int a;
    private int b;

    // Setter methods
    public void setA(int a) {
        this.a = a;
    }

    public void setB(int b) {
        this.b = b;
    }

    // Getter methods
    public int getA() {
        return a;
    }

    public int getB() {
        return b;
    }

    // Abstract method
    public abstract int add();
}