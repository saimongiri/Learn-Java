public abstract class Adder {
    private int a;
    private int b;
    public void setA(int a) {
        this.a = a;
    }
    public void setB(int b) {
        this.b = b;
    }
    public int getA() {
        return a;
    }
    public int getB() {
        return b;
    }
    public abstract int add();
    public void display() {
        System.out.println("The sum is: " + add());
    }
}